{
  "name": "qyearsley.github.io",
  "version": "1.0.0",
  "description": "Github Pages Site",
  "type": "module",
  "scripts": {
    "lint": "npm run lint:js && npm run lint:html && npm run lint:css",
    "lint:js": "eslint javascript/ games/ shared/ build.js build.test.js",
    "lint:html": "htmlhint \"**/*.html\" --ignore \"node_modules/**,coverage/**,dist/**\"",
    "lint:css": "stylelint \"**/*.css\" --ignore-pattern \"node_modules/**\" --ignore-pattern \"coverage/**\"",
    "format": "npx prettier --write .",
    "build": "node build.js",
    "start": "npm run build && http-server dist -p 8000",
    "dev": "http-server -p 8000",
    "test": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qyearsley/qyearsley.github.io.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@jest/globals": "^30.2.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.0",
    "eslint-plugin-import": "^2.32.0",
    "htmlhint": "^1.7.1",
    "http-server": "^14.1.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.6",
    "marked": "^18.0.2",
    "prettier": "^3.6.0",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1"
  },
  "lint-staged": {
    "*.js": [
      "eslint"
    ],
    "*.html": [
      "htmlhint"
    ],
    "*.css": [
      "stylelint"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "semi": false
  },
  "stylelint": {
    "extends": "stylelint-config-standard",
    "rules": {
      "selector-class-pattern": null,
      "selector-id-pattern": null,
      "custom-property-pattern": null,
      "color-function-notation": "legacy",
      "alpha-value-notation": "number",
      "no-descending-specificity": null
    }
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "silent": true,
    "collectCoverageFrom": [
      "build.js",
      "shared/**/*.js",
      "javascript/**/*.js",
      "games/number-garden/**/*.js",
      "games/turing-tape/**/*.js",
      "games/life-garden/**/*.js",
      "games/shared/**/*.js",
      "!**/*.test.js",
      "!**/*.html"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "transform": {},
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
